{
  "name": "@postlane/cli",
  "version": "0.1.5",
  "description": "Postlane CLI",
  "repository": {
    "type": "git",
    "url": "https://github.com/postlane/cli"
  },
  "license": "BUSL-1.1",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "postlane": "./dist/index.js"
  },
  "files": [
    "dist",
    "bundled-skills"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "node -e \"require('fs').chmodSync('dist/index.js', 0o755)\"",
    "test": "vitest run",
    "prebuild": "node scripts/copy-skills.js",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "prepublishOnly": "npm run clean && npm run build && npm test"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "inquirer": "^9.3.8"
  },
  "overrides": {
    "vite": ">=8.0.16"
  }
}
